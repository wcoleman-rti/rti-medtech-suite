# Docker Compose environment configuration for rti-medtech-suite
# Copy this file to .env and adjust paths for your system:
#   cp .env.example .env
#
# NDDSHOME is read from the shell environment (set by rtisetenv).
# If not set, the default /opt/rti.com/rti_connext_dds-7.6.0 is used.

# Path to RTI license file (required for CDS and Collector Service)
RTI_LICENSE_FILE=./rti_license.dat
