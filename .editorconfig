# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{cmake,txt}]
indent_size = 4

[Makefile]
indent_style = tab

[*.xml]
indent_size = 4

[*.idl]
indent_size = 4
