<?xml version="1.0" encoding="UTF-8"?>
<!--
    Routing Service Configuration — Procedure domain to Hospital domain bridge.

    Bridges selected topics from the Procedure domain (Domain 10) to the
    Hospital domain (Domain 11). Three input participants cover the three
    Procedure domain tags (control, clinical, operational). One output
    participant publishes on the Hospital domain (no tag).

    Partition strategy: all Routing Service participants use wildcard
    partition "room/*/procedure/*" at the DomainParticipant QoS level
    (matching the project convention of participant-level partitions).
    Hospital domain subscribers that use compatible wildcard partitions
    (e.g., "room/*") will match the output participant.

    Sessions:
      - StatusSession:    low-rate status/state topics
      - StreamingSession: higher-rate telemetry

    Administration and monitoring are on Domain 20 (Observability).
-->
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.6.0/rti_routing_service.xsd">

    <qos_library name="RSProfiles">

        <!--
            BridgedState: QoS for all bridged topics (State pattern).
            Matches the application-side TopicProfiles::State / Patterns::State:
            Reliable, TransientLocal, KeepLast 1, Automatic Liveliness 2 s.
        -->
        <qos_profile name="BridgedState">
            <datareader_qos>
                <reliability>
                    <kind>RELIABLE_RELIABILITY_QOS</kind>
                </reliability>
                <durability>
                    <kind>TRANSIENT_LOCAL_DURABILITY_QOS</kind>
                </durability>
                <history>
                    <kind>KEEP_LAST_HISTORY_QOS</kind>
                    <depth>1</depth>
                </history>
                <liveliness>
                    <kind>AUTOMATIC_LIVELINESS_QOS</kind>
                    <lease_duration>
                        <sec>2</sec>
                        <nanosec>0</nanosec>
                    </lease_duration>
                </liveliness>
            </datareader_qos>
            <datawriter_qos>
                <reliability>
                    <kind>RELIABLE_RELIABILITY_QOS</kind>
                </reliability>
                <durability>
                    <kind>TRANSIENT_LOCAL_DURABILITY_QOS</kind>
                </durability>
                <history>
                    <kind>KEEP_LAST_HISTORY_QOS</kind>
                    <depth>1</depth>
                </history>
                <liveliness>
                    <kind>AUTOMATIC_LIVELINESS_QOS</kind>
                    <lease_duration>
                        <sec>2</sec>
                        <nanosec>0</nanosec>
                    </lease_duration>
                </liveliness>
            </datawriter_qos>
        </qos_profile>

        <!--
            RSTransport: Docker transport — multicast disabled, CDS discovery.
            Composes with BuiltinQosSnippetLib for IP fragmentation avoidance.
        -->
        <qos_profile name="RSTransport">
            <domain_participant_qos>
                <transport_builtin>
                    <mask>UDPv4</mask>
                </transport_builtin>
                <discovery>
                    <initial_peers>
                        <element>builtin.shmem://</element>
                        <element>builtin.udpv4://localhost</element>
                        <element>rtps@udpv4://cloud-discovery-service:7400</element>
                    </initial_peers>
                    <multicast_receive_addresses/>
                </discovery>
                <property>
                    <value>
                        <element>
                            <name>dds.transport.UDPv4.builtin.multicast_enabled</name>
                            <value>0</value>
                        </element>
                    </value>
                </property>
            </domain_participant_qos>
        </qos_profile>

    </qos_library>

    <routing_service name="MedtechBridge">

        <annotation>
            <documentation>
                Bridges selected topics from Procedure domain (10) to
                Hospital domain (11). Only explicitly configured topics
                cross this boundary.
            </documentation>
        </annotation>

        <!-- Remote administration on Observability domain -->
        <administration>
            <domain_id>20</domain_id>
            <distributed_logger>
                <enabled>true</enabled>
                <filter_level>WARNING</filter_level>
            </distributed_logger>
        </administration>

        <!-- Remote monitoring on Observability domain -->
        <monitoring>
            <enabled>true</enabled>
            <domain_id>20</domain_id>
            <status_publication_period>
                <sec>5</sec>
                <nanosec>0</nanosec>
            </status_publication_period>
            <statistics_sampling_period>
                <sec>1</sec>
                <nanosec>0</nanosec>
            </statistics_sampling_period>
        </monitoring>

        <domain_route name="ProcedureToHospital">

            <!-- ── Input participants: Procedure domain (10) ───────── -->

            <!--
                RS::ProcedureControl — reads RobotState (control tag).
            -->
            <participant name="ProcedureControl">
                <domain_id>10</domain_id>
                <domain_participant_qos base_name="RSProfiles::RSTransport">
                    <partition>
                        <name>
                            <element>room/*/procedure/*</element>
                        </name>
                    </partition>
                    <property>
                        <value>
                            <element>
                                <name>dds.domain_participant.domain_tag</name>
                                <value>control</value>
                            </element>
                        </value>
                    </property>
                </domain_participant_qos>
            </participant>

            <!--
                RS::ProcedureClinical — reads PatientVitals, AlarmMessages,
                DeviceTelemetry (clinical tag).
            -->
            <participant name="ProcedureClinical">
                <domain_id>10</domain_id>
                <domain_participant_qos base_name="RSProfiles::RSTransport">
                    <partition>
                        <name>
                            <element>room/*/procedure/*</element>
                        </name>
                    </partition>
                    <property>
                        <value>
                            <element>
                                <name>dds.domain_participant.domain_tag</name>
                                <value>clinical</value>
                            </element>
                        </value>
                    </property>
                </domain_participant_qos>
            </participant>

            <!--
                RS::ProcedureOperational — reads ProcedureStatus,
                ProcedureContext (operational tag).
            -->
            <participant name="ProcedureOperational">
                <domain_id>10</domain_id>
                <domain_participant_qos base_name="RSProfiles::RSTransport">
                    <partition>
                        <name>
                            <element>room/*/procedure/*</element>
                        </name>
                    </partition>
                    <property>
                        <value>
                            <element>
                                <name>dds.domain_participant.domain_tag</name>
                                <value>operational</value>
                            </element>
                        </value>
                    </property>
                </domain_participant_qos>
            </participant>

            <!-- ── Output participant: Hospital domain (11) ────────── -->

            <!--
                RS::Hospital — writes all bridged topics. No domain tag.
                Participant partition "room/*/procedure/*" enables
                Hospital domain subscribers to match via wildcard.
            -->
            <participant name="Hospital">
                <domain_id>11</domain_id>
                <domain_participant_qos base_name="RSProfiles::RSTransport">
                    <partition>
                        <name>
                            <element>room/*/procedure/*</element>
                        </name>
                    </partition>
                </domain_participant_qos>
            </participant>

            <!-- ───────────────────────────────────────────────────── -->
            <!-- StatusSession: low-rate status/state topics           -->
            <!-- ───────────────────────────────────────────────────── -->
            <session name="StatusSession">

                <topic_route name="ProcedureStatusRoute">
                    <publish_with_original_timestamp>true</publish_with_original_timestamp>
                    <input participant="ProcedureOperational">
                        <topic_name>ProcedureStatus</topic_name>
                        <datareader_qos base_name="RSProfiles::BridgedState"/>
                    </input>
                    <output participant="Hospital">
                        <topic_name>ProcedureStatus</topic_name>
                        <datawriter_qos base_name="RSProfiles::BridgedState"/>
                    </output>
                </topic_route>

                <topic_route name="ProcedureContextRoute">
                    <publish_with_original_timestamp>true</publish_with_original_timestamp>
                    <input participant="ProcedureOperational">
                        <topic_name>ProcedureContext</topic_name>
                        <datareader_qos base_name="RSProfiles::BridgedState"/>
                    </input>
                    <output participant="Hospital">
                        <topic_name>ProcedureContext</topic_name>
                        <datawriter_qos base_name="RSProfiles::BridgedState"/>
                    </output>
                </topic_route>

                <topic_route name="AlarmMessagesRoute">
                    <publish_with_original_timestamp>true</publish_with_original_timestamp>
                    <input participant="ProcedureClinical">
                        <topic_name>AlarmMessages</topic_name>
                        <datareader_qos base_name="RSProfiles::BridgedState"/>
                    </input>
                    <output participant="Hospital">
                        <topic_name>AlarmMessages</topic_name>
                        <datawriter_qos base_name="RSProfiles::BridgedState"/>
                    </output>
                </topic_route>

            </session>

            <!-- ───────────────────────────────────────────────────── -->
            <!-- StreamingSession: higher-rate telemetry               -->
            <!-- ───────────────────────────────────────────────────── -->
            <session name="StreamingSession">

                <topic_route name="PatientVitalsRoute">
                    <publish_with_original_timestamp>true</publish_with_original_timestamp>
                    <input participant="ProcedureClinical">
                        <topic_name>PatientVitals</topic_name>
                        <datareader_qos base_name="RSProfiles::BridgedState"/>
                    </input>
                    <output participant="Hospital">
                        <topic_name>PatientVitals</topic_name>
                        <datawriter_qos base_name="RSProfiles::BridgedState"/>
                    </output>
                </topic_route>

                <topic_route name="DeviceTelemetryRoute">
                    <publish_with_original_timestamp>true</publish_with_original_timestamp>
                    <input participant="ProcedureClinical">
                        <topic_name>DeviceTelemetry</topic_name>
                        <datareader_qos base_name="RSProfiles::BridgedState"/>
                    </input>
                    <output participant="Hospital">
                        <topic_name>DeviceTelemetry</topic_name>
                        <datawriter_qos base_name="RSProfiles::BridgedState"/>
                    </output>
                </topic_route>

                <topic_route name="RobotStateRoute">
                    <publish_with_original_timestamp>true</publish_with_original_timestamp>
                    <input participant="ProcedureControl">
                        <topic_name>RobotState</topic_name>
                        <datareader_qos base_name="RSProfiles::BridgedState"/>
                    </input>
                    <output participant="Hospital">
                        <topic_name>RobotState</topic_name>
                        <datawriter_qos base_name="RSProfiles::BridgedState"/>
                    </output>
                </topic_route>

            </session>

        </domain_route>

    </routing_service>

</dds>
