<?xml version="1.0" encoding="UTF-8"?>
<!--
    Routing Service Configuration — Procedure + Orchestration → Hospital bridge.

    Bridges selected topics from the Procedure databuses and
    Orchestration databus to the Hospital Integration databus.
    Three input participants cover the three Procedure databuses
    (control, clinical, operational). A fourth input participant reads
    ServiceCatalog from Orchestration. One output participant publishes
    on the Hospital Integration databus (no tag).

    Participants: 6 total
      - ProcedureControl       (Procedure control databus)
      - ProcedureClinical      (Procedure clinical databus)
      - ProcedureOperational   (Procedure operational databus)
      - ProcedureOrchestration (Orchestration databus)
      - Hospital               (Hospital Integration databus, output)

    QoS profiles are loaded from the project QoS files via NDDS_QOS_PROFILES
    environment variable — the same profiles used by all applications.
    Reader/writer QoS is resolved via topic_filter entries in the Topics::
    profiles so every topic gets its specific QoS (deadlines, liveliness, etc.)
    without any profile redefinition in this file.

    Partition strategy: Procedure-side participants use wildcard partition
    "room/*/procedure/*" at the DomainParticipant QoS level. The Hospital
    output participant has no partition — all bridged data merges into the
    facility-wide view.

    Sessions:
      - StatusSession:    low-rate status/state topics + ServiceCatalog
      - StreamingSession: higher-rate telemetry

    Administration and monitoring are on the Room Observability databus.
-->
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.6.0/rti_routing_service.xsd">

    <routing_service name="MedtechBridge">

        <annotation>
            <documentation>
                Bridges selected topics from Procedure databuses and
                Orchestration databus to Hospital Integration databus. Only
                explicitly configured topics cross this boundary.
            </documentation>
        </annotation>

        <!-- Remote administration on Room Observability databus.
             Disabled: the Participants::Transport QoS profile sets
             autoenable_created_entities=false, which conflicts with
             RS's internal admin participant. Enable when a dedicated
             admin QoS profile is available. -->
        <!--
        <administration>
            <domain_id>19</domain_id>
            <distributed_logger>
                <enabled>true</enabled>
                <filter_level>WARNING</filter_level>
            </distributed_logger>
        </administration>
        -->

        <!-- Remote monitoring on Room Observability databus — disabled (same reason). -->
        <!--
        <monitoring>
            <enabled>true</enabled>
            <domain_id>19</domain_id>
            <status_publication_period>
                <sec>5</sec>
                <nanosec>0</nanosec>
            </status_publication_period>
            <statistics_sampling_period>
                <sec>1</sec>
                <nanosec>0</nanosec>
            </statistics_sampling_period>
        </monitoring>
        -->

        <domain_route name="ProcedureToHospital">

            <!-- ── Input participants: Procedure databuses ───────────── -->

            <!--
                RS::ProcedureControl — reads RobotState (control tag).
            -->
            <participant name="ProcedureControl">
                <domain_id>10</domain_id>
                <domain_participant_qos base_name="Participants::Transport">
                    <partition>
                        <name>
                            <element>room/*/procedure/*</element>
                        </name>
                    </partition>
                    <property>
                        <value>
                            <element>
                                <name>dds.domain_participant.domain_tag</name>
                                <value>control</value>
                            </element>
                        </value>
                    </property>
                </domain_participant_qos>
            </participant>

            <!--
                RS::ProcedureClinical — reads PatientVitals, AlarmMessages,
                DeviceTelemetry (clinical tag).
            -->
            <participant name="ProcedureClinical">
                <domain_id>10</domain_id>
                <domain_participant_qos base_name="Participants::Transport">
                    <partition>
                        <name>
                            <element>room/*/procedure/*</element>
                        </name>
                    </partition>
                    <property>
                        <value>
                            <element>
                                <name>dds.domain_participant.domain_tag</name>
                                <value>clinical</value>
                            </element>
                        </value>
                    </property>
                </domain_participant_qos>
            </participant>

            <!--
                RS::ProcedureOperational — reads ProcedureStatus,
                ProcedureContext (operational tag).
            -->
            <participant name="ProcedureOperational">
                <domain_id>10</domain_id>
                <domain_participant_qos base_name="Participants::Transport">
                    <partition>
                        <name>
                            <element>room/*/procedure/*</element>
                        </name>
                    </partition>
                    <property>
                        <value>
                            <element>
                                <name>dds.domain_participant.domain_tag</name>
                                <value>operational</value>
                            </element>
                        </value>
                    </property>
                </domain_participant_qos>
            </participant>

            <!-- ── Input participant: Orchestration databus ────────── -->

            <!--
                RS::ProcedureOrchestration — reads ServiceCatalog from the
                Orchestration databus (room-scoped) for northbound extraction
                to the Hospital Integration databus.
            -->
            <participant name="ProcedureOrchestration">
                <domain_id>11</domain_id>
                <domain_participant_qos base_name="Participants::Transport">
                    <partition>
                        <name>
                            <element>procedure</element>
                        </name>
                    </partition>
                </domain_participant_qos>
            </participant>

            <!-- ── Output participant: Hospital Integration databus ──── -->

            <!--
                RS::Hospital — writes all bridged topics. No domain tag.
                No partition — Hospital Integration databus merges all room/procedure
                data into a facility-wide view.
            -->
            <participant name="Hospital">
                <domain_id>20</domain_id>
                <domain_participant_qos base_name="Participants::Transport"/>
            </participant>

            <!-- ───────────────────────────────────────────────────── -->
            <!-- StatusSession: low-rate status/state topics           -->
            <!-- ───────────────────────────────────────────────────── -->
            <session name="StatusSession">

                <topic_route name="ProcedureStatusRoute">
                    <publish_with_original_info>true</publish_with_original_info>
                    <publish_with_original_timestamp>true</publish_with_original_timestamp>
                    <filter_propagation>
                        <enabled>true</enabled>
                    </filter_propagation>
                    <input participant="ProcedureOperational">
                        <topic_name>ProcedureStatus</topic_name>
                        <datareader_qos base_name="Topics::ProcedureTopics"/>
                    </input>
                    <output participant="Hospital">
                        <topic_name>ProcedureStatus</topic_name>
                        <datawriter_qos base_name="Topics::HospitalTopics"/>
                    </output>
                </topic_route>

                <topic_route name="ProcedureContextRoute">
                    <publish_with_original_info>true</publish_with_original_info>
                    <publish_with_original_timestamp>true</publish_with_original_timestamp>
                    <filter_propagation>
                        <enabled>true</enabled>
                    </filter_propagation>
                    <input participant="ProcedureOperational">
                        <topic_name>ProcedureContext</topic_name>
                        <datareader_qos base_name="Topics::ProcedureTopics"/>
                    </input>
                    <output participant="Hospital">
                        <topic_name>ProcedureContext</topic_name>
                        <datawriter_qos base_name="Topics::HospitalTopics"/>
                    </output>
                </topic_route>

                <topic_route name="AlarmMessagesRoute">
                    <publish_with_original_info>true</publish_with_original_info>
                    <publish_with_original_timestamp>true</publish_with_original_timestamp>
                    <filter_propagation>
                        <enabled>true</enabled>
                    </filter_propagation>
                    <input participant="ProcedureClinical">
                        <topic_name>AlarmMessages</topic_name>
                        <datareader_qos base_name="Topics::ProcedureTopics"/>
                    </input>
                    <output participant="Hospital">
                        <topic_name>AlarmMessages</topic_name>
                        <datawriter_qos base_name="Topics::HospitalTopics"/>
                    </output>
                </topic_route>

                <topic_route name="ServiceCatalogRoute">
                    <publish_with_original_info>true</publish_with_original_info>
                    <publish_with_original_timestamp>true</publish_with_original_timestamp>
                    <input participant="ProcedureOrchestration">
                        <topic_name>ServiceCatalog</topic_name>
                        <datareader_qos base_name="TopicProfiles::ServiceCatalog"/>
                    </input>
                    <output participant="Hospital">
                        <topic_name>ServiceCatalog</topic_name>
                        <datawriter_qos base_name="TopicProfiles::ServiceCatalog"/>
                    </output>
                </topic_route>

            </session>

            <!-- ───────────────────────────────────────────────────── -->
            <!-- StreamingSession: higher-rate telemetry               -->
            <!-- ───────────────────────────────────────────────────── -->
            <session name="StreamingSession">

                <topic_route name="PatientVitalsRoute">
                    <publish_with_original_info>true</publish_with_original_info>
                    <publish_with_original_timestamp>true</publish_with_original_timestamp>
                    <filter_propagation>
                        <enabled>true</enabled>
                    </filter_propagation>
                    <input participant="ProcedureClinical">
                        <topic_name>PatientVitals</topic_name>
                        <datareader_qos base_name="Topics::ProcedureTopics"/>
                    </input>
                    <output participant="Hospital">
                        <topic_name>PatientVitals</topic_name>
                        <datawriter_qos base_name="Topics::HospitalTopics"/>
                    </output>
                </topic_route>

                <topic_route name="DeviceTelemetryRoute">
                    <publish_with_original_info>true</publish_with_original_info>
                    <publish_with_original_timestamp>true</publish_with_original_timestamp>
                    <filter_propagation>
                        <enabled>true</enabled>
                    </filter_propagation>
                    <input participant="ProcedureClinical">
                        <topic_name>DeviceTelemetry</topic_name>
                        <datareader_qos base_name="Topics::ProcedureTopics"/>
                    </input>
                    <output participant="Hospital">
                        <topic_name>DeviceTelemetry</topic_name>
                        <datawriter_qos base_name="Topics::HospitalTopics"/>
                    </output>
                </topic_route>

                <topic_route name="RobotStateRoute">
                    <publish_with_original_info>true</publish_with_original_info>
                    <publish_with_original_timestamp>true</publish_with_original_timestamp>
                    <filter_propagation>
                        <enabled>true</enabled>
                    </filter_propagation>
                    <input participant="ProcedureControl">
                        <topic_name>RobotState</topic_name>
                        <datareader_qos base_name="Topics::ProcedureTopics"/>
                    </input>
                    <output participant="Hospital">
                        <topic_name>RobotState</topic_name>
                        <datawriter_qos base_name="Topics::HospitalTopics"/>
                    </output>
                </topic_route>

            </session>

        </domain_route>

    </routing_service>

</dds>
