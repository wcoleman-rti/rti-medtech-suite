#!/usr/bin/env bash
# Auto-generated by CMake install. Do not edit.
_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_ROOT="$(dirname "$_DIR")"

# RTI Connext DDS environment (library paths, NDDSHOME, CONNEXTDDS_DIR)
# Priority: runtime NDDSHOME/CONNEXTDDS_DIR > build-time baked path
_CONNEXT_HOME="${NDDSHOME:-${CONNEXTDDS_DIR:-@CONNEXTDDS_DIR@}}"
_CONNEXT_ARCH="${CONNEXTDDS_ARCH:-@CONNEXTDDS_ARCH@}"

if [[ ":${LD_LIBRARY_PATH:-}:" == *":${_CONNEXT_HOME}/lib/${_CONNEXT_ARCH}:"* ]]; then
    # Connext libs already on LD_LIBRARY_PATH — skip
    :
elif [[ -f "${_CONNEXT_HOME}/resource/scripts/rtisetenv_${_CONNEXT_ARCH}.bash" ]]; then
    source "${_CONNEXT_HOME}/resource/scripts/rtisetenv_${_CONNEXT_ARCH}.bash"
fi

# Activate Python venv (pip-installed: rti.connext, nicegui, pytest)
if [[ -f "$_ROOT/.venv/bin/activate" ]]; then
    source "$_ROOT/.venv/bin/activate"
fi

# Project install paths
export PATH="$_DIR/bin:$PATH"
export LD_LIBRARY_PATH="$_DIR/lib:${LD_LIBRARY_PATH:-}"
export PYTHONPATH="$_DIR/lib/python/site-packages:${PYTHONPATH:-}"

# QoS + domain library + participant XML in dependency order
export NDDS_QOS_PROFILES="$_DIR/share/qos/Snippets.xml;\
$_DIR/share/qos/Patterns.xml;\
$_DIR/share/qos/Topics.xml;\
$_DIR/share/qos/Participants.xml;\
$_DIR/share/domains/RoomDatabuses.xml;\
$_DIR/share/domains/HospitalDatabuses.xml;\
$_DIR/share/domains/CloudDatabuses.xml;\
$_DIR/share/participants/SurgicalParticipants.xml;\
$_DIR/share/participants/OrchestrationParticipants.xml"

# Runtime configuration root
export MEDTECH_CONFIG_DIR="$_DIR/etc"

# Shared GUI resources (fonts, images, stylesheets)
export MEDTECH_RESOURCE_DIR="$_DIR/share/resources"

# Prometheus endpoint for performance benchmarks (observability stack)
export PROMETHEUS_URL="${PROMETHEUS_URL:-http://localhost:9090}"

# Monitoring Library 2.0 application name (set per process before launch)
export MEDTECH_APP_NAME="${MEDTECH_APP_NAME:-unknown}"
