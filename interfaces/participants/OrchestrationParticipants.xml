<?xml version="1.0" encoding="UTF-8"?>
<!--
    Orchestration Module — Participant Library

    Defines named participant configurations for the Orchestration databus.
    No domain tags. Partition is set programmatically after
    participant creation (room/<room_id> or "unassigned").

    Participant library naming:
      OrchestrationParticipants::<name>

    Entity naming convention for find_datawriter / find_datareader:
      "PublisherName::WriterName"  or  "SubscriberName::ReaderName"
-->
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.6.0/rti_dds_profiles.xsd">

    <domain_participant_library name="OrchestrationParticipants">

        <!--
            Orchestration — Service Host participant on the Orchestration databus.
            Publishes: ServiceCatalog, ServiceStatus
            Subscribes: (none via pub/sub — RPC handled by generated entities)
            RPC: ServiceHostControl service endpoint
        -->
        <domain_participant name="Orchestration"
                            domain_ref="Room::Orchestration">
            <domain_participant_qos base_name="Participants::Transport"/>

            <publisher name="OrchestrationPublisher">

                <data_writer name="ServiceCatalogWriter"
                             topic_ref="ServiceCatalog">
                    <datawriter_qos base_name="TopicProfiles::ServiceCatalog"/>
                </data_writer>

                <data_writer name="ServiceStatusWriter"
                             topic_ref="ServiceStatus">
                    <datawriter_qos base_name="TopicProfiles::ServiceStatus"/>
                </data_writer>
            </publisher>

            <subscriber name="OrchestrationSubscriber">

                <data_reader name="ServiceCatalogReader"
                             topic_ref="ServiceCatalog">
                    <datareader_qos base_name="TopicProfiles::ServiceCatalog"/>
                </data_reader>

                <data_reader name="ServiceStatusReader"
                             topic_ref="ServiceStatus">
                    <datareader_qos base_name="TopicProfiles::ServiceStatus"/>
                </data_reader>
            </subscriber>
        </domain_participant>

        <!--
            ProcedureController_Orchestration — Controller's Orchestration databus
            participant. Subscribes to ServiceCatalog and ServiceStatus.
            RPC: ServiceHostControl client endpoint.
        -->
        <domain_participant name="ProcedureController_Orchestration"
                            domain_ref="Room::Orchestration">
            <domain_participant_qos base_name="Participants::Transport"/>

            <subscriber name="ControllerOrchSubscriber">

                <data_reader name="ServiceCatalogReader"
                             topic_ref="ServiceCatalog">
                    <datareader_qos base_name="TopicProfiles::ServiceCatalog"/>
                </data_reader>

                <data_reader name="ServiceStatusReader"
                             topic_ref="ServiceStatus">
                    <datareader_qos base_name="TopicProfiles::ServiceStatus"/>
                </data_reader>
            </subscriber>
        </domain_participant>

        <!--
            RoomNav — Lightweight read-only Orchestration participant for
            room-level GUI navigation.  Discovers sibling GUIs via
            ServiceCatalog filtered by room_id in application code.
        -->
        <domain_participant name="RoomNav"
                            domain_ref="Room::Orchestration">
            <domain_participant_qos base_name="Participants::Transport"/>

            <subscriber name="RoomNavSubscriber">

                <data_reader name="ServiceCatalogReader"
                             topic_ref="ServiceCatalog">
                    <datareader_qos base_name="TopicProfiles::ServiceCatalog"/>
                </data_reader>

            </subscriber>
        </domain_participant>

    </domain_participant_library>

</dds>
