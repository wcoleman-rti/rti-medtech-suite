/*
 * Imaging module types — camera frames and stream configuration.
 *
 * Module: Imaging
 * Domain: Procedure (operational tag)
 * All types are @appendable.
 *
 * CameraFrame carries inline compressed image data. Field-semantically
 * aligned with Foxglove CompressedImage (timestamp, frame_id, data, format)
 * but not wire-compatible due to @key camera_id (see INC-027).
 *
 * CameraConfig is a separate state topic for stream configuration
 * (resolution, encoding, exposure) — published write-on-change with
 * TRANSIENT_LOCAL durability. Correlated with CameraFrame via camera_id.
 */

#include "common/common.idl"

module Imaging {

    // --- Topic Types ---

    // Topic: CameraFrame | Domain Tag: operational | Pattern: Stream
    @appendable
    struct CameraFrame {
        @key Common::EntityId camera_id;
        Common::Time_t timestamp;
        string<Common::MAX_NAME_LENGTH> frame_id;
        sequence<uint8, Common::MAX_FRAME_SIZE> data;
        string<16> format;
    };

    // Topic: CameraConfig | Domain Tag: operational | Pattern: State
    @appendable
    struct CameraConfig {
        @key Common::EntityId camera_id;
        uint32 width;
        uint32 height;
        string<32> encoding;
        uint32 exposure_us;
        float compression_ratio;
    };

};
