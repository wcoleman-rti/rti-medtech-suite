/*
 * Entity name constants for XML Application Creation.
 *
 * Each participant library XML gets its own nested module. Every
 * participant, DataWriter, and DataReader name defined in an XML
 * participant configuration file has a corresponding const string here.
 *
 * C++ (IDL4_CPP):  generates std::string_view constants
 * Python:          generates module-level constants
 *
 * Application code references these constants — never raw string literals.
 */

module MedtechEntityNames {

    // --- SurgicalParticipants library ---
    module SurgicalParticipants {

        // Participant config names — create_participant_from_config()
        const string OPERATIONAL_PUB      = "SurgicalParticipants::OperationalPub";
        const string CONTROL_ROBOT        = "SurgicalParticipants::ControlRobot";
        const string CONTROL_OPERATOR     = "SurgicalParticipants::ControlOperator";
        const string CLINICAL_MONITOR     = "SurgicalParticipants::ClinicalMonitor";
        const string CLINICAL_DEVICE_GW   = "SurgicalParticipants::ClinicalDeviceGateway";
        const string CONTROL_DIGITAL_TWIN = "SurgicalParticipants::ControlDigitalTwin";
        const string PROCEDURE_CONTROLLER_PROCEDURE_CONTROL = "SurgicalParticipants::ProcedureController_ProcedureControl";

        // Writer names — find_datawriter_by_name() / find_datawriter()
        const string PROCEDURE_CONTEXT_WRITER  = "OperationalPublisher::ProcedureContextWriter";
        const string PROCEDURE_STATUS_WRITER   = "OperationalPublisher::ProcedureStatusWriter";
        const string CAMERA_FRAME_WRITER       = "OperationalPublisher::CameraFrameWriter";
        const string CAMERA_CONFIG_WRITER      = "OperationalPublisher::CameraConfigWriter";
        const string ROBOT_STATE_WRITER        = "RobotPublisher::RobotStateWriter";
        const string ROBOT_ARM_ASSIGNMENT_WRITER = "RobotPublisher::RobotArmAssignmentWriter";
        const string OPERATOR_INPUT_WRITER     = "OperatorPublisher::OperatorInputWriter";
        const string ROBOT_COMMAND_WRITER      = "OperatorPublisher::RobotCommandWriter";
        const string SAFETY_INTERLOCK_WRITER   = "OperatorPublisher::SafetyInterlockWriter";
        const string PATIENT_VITALS_WRITER     = "MonitorPublisher::PatientVitalsWriter";
        const string WAVEFORM_DATA_WRITER      = "MonitorPublisher::WaveformDataWriter";
        const string ALARM_MESSAGES_WRITER     = "MonitorPublisher::AlarmMessagesWriter";
        const string DEVICE_TELEMETRY_WRITER   = "DevicePublisher::DeviceTelemetryWriter";

        // Reader names — find_datareader_by_name() / find_datareader()
        const string ROBOT_COMMAND_READER      = "RobotSubscriber::RobotCommandReader";
        const string OPERATOR_INPUT_READER     = "RobotSubscriber::OperatorInputReader";
        const string SAFETY_INTERLOCK_READER   = "RobotSubscriber::SafetyInterlockReader";
        const string ROBOT_STATE_READER        = "OperatorSubscriber::RobotStateReader";
        const string PROCEDURE_CONTEXT_READER  = "OperationalSubscriber::ProcedureContextReader";
        const string PROCEDURE_STATUS_READER   = "OperationalSubscriber::ProcedureStatusReader";
        const string PATIENT_VITALS_READER     = "MonitorSubscriber::PatientVitalsReader";
        const string TWIN_ROBOT_STATE_READER       = "TwinSubscriber::RobotStateReader";
        const string TWIN_OPERATOR_INPUT_READER    = "TwinSubscriber::OperatorInputReader";
        const string TWIN_SAFETY_INTERLOCK_READER  = "TwinSubscriber::SafetyInterlockReader";
        const string TWIN_ROBOT_COMMAND_READER     = "TwinSubscriber::RobotCommandReader";
        const string TWIN_ROBOT_ARM_ASSIGNMENT_READER = "TwinSubscriber::RobotArmAssignmentReader";
        const string CTRL_ROBOT_ARM_ASSIGNMENT_READER = "ProcedureControlSubscriber::RobotArmAssignmentReader";

        // ProcedureController_Procedure_Operational — Domain 10 operational reads
        const string PROCEDURE_CONTROLLER_PROCEDURE_OPERATIONAL =
            "SurgicalParticipants::ProcedureController_Procedure_Operational";
        const string CTRL_PROCEDURE_STATUS_READER =
            "ControllerProcOpSubscriber::ProcedureStatusReader";
        const string CTRL_PROCEDURE_CONTEXT_READER =
            "ControllerProcOpSubscriber::ProcedureContextReader";
    };

    // --- OrchestrationParticipants library ---
    module OrchestrationParticipants {

        // Participant config names — create_participant_from_config()
        const string ORCHESTRATION                    = "OrchestrationParticipants::Orchestration";
        const string PROCEDURE_CONTROLLER_ORCHESTRATION = "OrchestrationParticipants::ProcedureController_Orchestration";

        // Writer names — find_datawriter_by_name() / find_datawriter()
        const string SERVICE_CATALOG_WRITER  = "OrchestrationPublisher::ServiceCatalogWriter";
        const string SERVICE_STATUS_WRITER   = "OrchestrationPublisher::ServiceStatusWriter";

        // Reader names — find_datareader_by_name() / find_datareader()
        const string SERVICE_CATALOG_READER  = "OrchestrationSubscriber::ServiceCatalogReader";
        const string SERVICE_STATUS_READER   = "OrchestrationSubscriber::ServiceStatusReader";

        // Controller reader names
        const string CTRL_SERVICE_CATALOG_READER = "ControllerOrchSubscriber::ServiceCatalogReader";
        const string CTRL_SERVICE_STATUS_READER  = "ControllerOrchSubscriber::ServiceStatusReader";
    };

    // --- RoomNav participant (in OrchestrationParticipants library) ---
    module RoomNav {
        const string ROOM_NAV                = "OrchestrationParticipants::RoomNav";
        const string SERVICE_CATALOG_READER  = "RoomNavSubscriber::ServiceCatalogReader";
    };

    // --- HospitalDashboard participant (in HospitalParticipants library) ---
    module HospitalDashboard {

        // Participant config name — create_participant_from_config()
        const string HOSPITAL_DASHBOARD = "HospitalParticipants::HospitalDashboard";

        // Reader names — find_datareader()
        const string PROCEDURE_STATUS_READER      = "DashboardSubscriber::ProcedureStatusReader";
        const string PROCEDURE_CONTEXT_READER     = "DashboardSubscriber::ProcedureContextReader";
        const string PATIENT_VITALS_READER        = "DashboardSubscriber::PatientVitalsReader";
        const string ALARM_MESSAGES_READER        = "DashboardSubscriber::AlarmMessagesReader";
        const string DEVICE_TELEMETRY_READER      = "DashboardSubscriber::DeviceTelemetryReader";
        const string ROBOT_STATE_READER           = "DashboardSubscriber::RobotStateReader";
        const string CLINICAL_ALERT_READER        = "DashboardSubscriber::ClinicalAlertReader";
        const string RESOURCE_AVAILABILITY_READER = "DashboardSubscriber::ResourceAvailabilityReader";
        const string SERVICE_CATALOG_READER       = "DashboardSubscriber::ServiceCatalogReader";
    };
};
