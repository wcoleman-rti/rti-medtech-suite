/*
 * Orchestration module types — service lifecycle, service catalog, RPC.
 *
 * Module: Orchestration
 * Domain: Orchestration (Domain 15, no domain tags)
 *
 * Contains:
 *   - ServiceState enum (single source of truth for medtech::Service)
 *   - OperationResultCode enum (RPC reply codes)
 *   - Pub/sub state types: ServiceCatalog, ServiceStatus
 *   - RPC parameter types: ServiceProperty, ServiceRequest,
 *     OperationResult, CapabilityReport, HealthReport
 *   - @service("DDS") interface: ServiceHostControl
 */

#include "common/common.idl"

module Orchestration {

    // --- Constants ---
    const long MAX_SERVICE_COUNT = 16;
    const long MAX_CONFIG_LENGTH = 1024;
    const long MAX_DIAG_LENGTH = 2048;
    const long MAX_PROPERTY_COUNT = 32;

    // --- Enums ---

    @appendable
    enum ServiceState {
        STOPPED,
        STARTING,
        RUNNING,
        STOPPING,
        FAILED,
        UNKNOWN
    };

    @appendable
    enum OperationResultCode {
        OK,
        INVALID_SERVICE,
        INVALID_CONFIG,
        BUSY,
        ALREADY_RUNNING,
        NOT_RUNNING,
        INTERNAL_ERROR
    };

    // --- Pub/Sub State Types ---

    // Property descriptor for service configuration advertisement.
    // Embedded in ServiceCatalog so the Procedure Controller can
    // render a configuration form at discovery time without an RPC
    // round-trip.  @appendable allows future additions (type hints,
    // units, allowed values, etc.) without breaking compatibility.
    @appendable @nested
    struct PropertyDescriptor {
        string<Common::MAX_NAME_LENGTH> name;
        string<MAX_CONFIG_LENGTH> current_value;
        @optional string<MAX_CONFIG_LENGTH> default_value;
        string<Common::MAX_DESCRIPTION_LENGTH> description;
        boolean required;
    };

    // Topic: ServiceCatalog | Pattern: State | Liveliness 2s
    // Dual-keyed: one DDS instance per (host, service) pair.
    // A Service Host writes N instances on startup — one per
    // registered service.  TRANSIENT_LOCAL + KEEP_LAST 1 gives
    // late-joining controllers the full picture immediately.
    // After update_service RPC, the host re-publishes with
    // updated property values.
    @appendable
    struct ServiceCatalog {
        @key Common::EntityId host_id;
        @key Common::EntityId service_id;
        string<Common::MAX_NAME_LENGTH> display_name;
        sequence<PropertyDescriptor, MAX_PROPERTY_COUNT> properties;
        @optional string<Common::MAX_DESCRIPTION_LENGTH> health_summary;
    };

    // Topic: ServiceStatus | Pattern: State
    @appendable
    struct ServiceStatus {
        @key Common::EntityId host_id;
        @key Common::EntityId service_id;
        ServiceState state;
        Common::Time_t timestamp;
    };

    // --- RPC Parameter Types ---

    @final @nested
    struct ServiceProperty {
        string<Common::MAX_NAME_LENGTH> name;
        string<MAX_CONFIG_LENGTH> value;
    };

    @appendable
    struct ServiceRequest {
        Common::EntityId service_id;
        sequence<ServiceProperty, MAX_PROPERTY_COUNT> properties;
    };

    @appendable
    struct OperationResult {
        OperationResultCode code;
        string<Common::MAX_DESCRIPTION_LENGTH> message;
    };

    @appendable
    struct CapabilityReport {
        int32 capacity;
    };

    @appendable
    struct HealthReport {
        boolean alive;
        string<Common::MAX_DESCRIPTION_LENGTH> summary;
        string<MAX_DIAG_LENGTH> diagnostics;
    };

    // --- RPC Service Interface ---

    @service("DDS")
    interface ServiceHostControl {
        OperationResult start_service(in ServiceRequest req);
        OperationResult stop_service(in Common::EntityId service_id);
        OperationResult update_service(in ServiceRequest req);
        CapabilityReport get_capabilities();
        HealthReport get_health();
    };

};
