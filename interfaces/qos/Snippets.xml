<?xml version="1.0" encoding="UTF-8"?>
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.6.0/rti_dds_profiles.xsd">

    <!--
        Isolated, composable QoS policy chunks — no inheritance.
        Only custom snippets are defined here. Builtin equivalents from
        BuiltinQosSnippetLib are used directly by Patterns and TopicProfiles:

            BuiltinQosSnippetLib::QosPolicy.Reliability.Reliable
            BuiltinQosSnippetLib::QosPolicy.Reliability.BestEffort
            BuiltinQosSnippetLib::QosPolicy.Durability.TransientLocal
            BuiltinQosSnippetLib::QosPolicy.History.KeepLast_1
            BuiltinQosSnippetLib::QosPolicy.History.KeepAll
    -->
    <qos_library name="Snippets">

        <!-- Durability: VOLATILE (no builtin equivalent) -->
        <qos_profile name="Volatile">
            <datawriter_qos>
                <durability>
                    <kind>VOLATILE_DURABILITY_QOS</kind>
                </durability>
            </datawriter_qos>
            <datareader_qos>
                <durability>
                    <kind>VOLATILE_DURABILITY_QOS</kind>
                </durability>
            </datareader_qos>
        </qos_profile>

        <!-- Ownership: EXCLUSIVE (no builtin equivalent) -->
        <qos_profile name="ExclusiveOwnership">
            <datawriter_qos>
                <ownership>
                    <kind>EXCLUSIVE_OWNERSHIP_QOS</kind>
                </ownership>
            </datawriter_qos>
            <datareader_qos>
                <ownership>
                    <kind>EXCLUSIVE_OWNERSHIP_QOS</kind>
                </ownership>
            </datareader_qos>
        </qos_profile>

        <!-- Liveliness -->
        <qos_profile name="Liveliness2s">
            <datawriter_qos>
                <liveliness>
                    <kind>AUTOMATIC_LIVELINESS_QOS</kind>
                    <lease_duration>
                        <sec>2</sec>
                        <nanosec>0</nanosec>
                    </lease_duration>
                </liveliness>
            </datawriter_qos>
            <datareader_qos>
                <liveliness>
                    <kind>AUTOMATIC_LIVELINESS_QOS</kind>
                    <lease_duration>
                        <sec>2</sec>
                        <nanosec>0</nanosec>
                    </lease_duration>
                </liveliness>
            </datareader_qos>
        </qos_profile>

        <qos_profile name="Liveliness500ms">
            <datawriter_qos>
                <liveliness>
                    <kind>AUTOMATIC_LIVELINESS_QOS</kind>
                    <lease_duration>
                        <sec>0</sec>
                        <nanosec>500000000</nanosec>
                    </lease_duration>
                </liveliness>
            </datawriter_qos>
            <datareader_qos>
                <liveliness>
                    <kind>AUTOMATIC_LIVELINESS_QOS</kind>
                    <lease_duration>
                        <sec>0</sec>
                        <nanosec>500000000</nanosec>
                    </lease_duration>
                </liveliness>
            </datareader_qos>
        </qos_profile>

        <!-- Deadline -->
        <qos_profile name="Deadline4ms">
            <datawriter_qos>
                <deadline>
                    <period>
                        <sec>0</sec>
                        <nanosec>4000000</nanosec>
                    </period>
                </deadline>
            </datawriter_qos>
            <datareader_qos>
                <deadline>
                    <period>
                        <sec>0</sec>
                        <nanosec>4000000</nanosec>
                    </period>
                </deadline>
            </datareader_qos>
        </qos_profile>

        <qos_profile name="Deadline20ms">
            <datawriter_qos>
                <deadline>
                    <period>
                        <sec>0</sec>
                        <nanosec>20000000</nanosec>
                    </period>
                </deadline>
            </datawriter_qos>
            <datareader_qos>
                <deadline>
                    <period>
                        <sec>0</sec>
                        <nanosec>20000000</nanosec>
                    </period>
                </deadline>
            </datareader_qos>
        </qos_profile>

        <qos_profile name="Deadline40ms">
            <datawriter_qos>
                <deadline>
                    <period>
                        <sec>0</sec>
                        <nanosec>40000000</nanosec>
                    </period>
                </deadline>
            </datawriter_qos>
            <datareader_qos>
                <deadline>
                    <period>
                        <sec>0</sec>
                        <nanosec>40000000</nanosec>
                    </period>
                </deadline>
            </datareader_qos>
        </qos_profile>

        <qos_profile name="Deadline66ms">
            <datawriter_qos>
                <deadline>
                    <period>
                        <sec>0</sec>
                        <nanosec>66000000</nanosec>
                    </period>
                </deadline>
            </datawriter_qos>
            <datareader_qos>
                <deadline>
                    <period>
                        <sec>0</sec>
                        <nanosec>66000000</nanosec>
                    </period>
                </deadline>
            </datareader_qos>
        </qos_profile>

        <qos_profile name="Deadline2s">
            <datawriter_qos>
                <deadline>
                    <period>
                        <sec>2</sec>
                        <nanosec>0</nanosec>
                    </period>
                </deadline>
            </datawriter_qos>
            <datareader_qos>
                <deadline>
                    <period>
                        <sec>2</sec>
                        <nanosec>0</nanosec>
                    </period>
                </deadline>
            </datareader_qos>
        </qos_profile>

        <!-- Lifespan -->
        <qos_profile name="Lifespan20ms">
            <datawriter_qos>
                <lifespan>
                    <duration>
                        <sec>0</sec>
                        <nanosec>20000000</nanosec>
                    </duration>
                </lifespan>
            </datawriter_qos>
        </qos_profile>

        <!-- GUI time-based filter for downsampled readers -->
        <qos_profile name="GuiSubsample">
            <datareader_qos>
                <time_based_filter>
                    <minimum_separation>
                        <sec>0</sec>
                        <nanosec>100000000</nanosec>
                    </minimum_separation>
                </time_based_filter>
            </datareader_qos>
        </qos_profile>

    </qos_library>

</dds>
