<?xml version="1.0" encoding="UTF-8"?>
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.6.0/rti_dds_profiles.xsd">

    <qos_library name="Topics">

        <!--
            ProcedureTopics: topic-filter-bound QoS for Procedure domain (Domain 10).
            Every topic-filtered entry explicitly declares its base pattern via
            the base_name attribute — no implicit inheritance from the profile.
        -->
        <qos_profile name="ProcedureTopics">

            <!-- OperatorInput: Stream + Deadline4ms + Lifespan20ms (500 Hz control) -->
            <datawriter_qos topic_filter="OperatorInput" base_name="Patterns::Stream">
                <base_name>
                    <element>Snippets::Deadline4ms</element>
                    <element>Snippets::Lifespan20ms</element>
                </base_name>
            </datawriter_qos>
            <datareader_qos topic_filter="OperatorInput" base_name="Patterns::Stream">
                <base_name>
                    <element>Snippets::Deadline4ms</element>
                    <element>Snippets::Lifespan20ms</element>
                </base_name>
            </datareader_qos>

            <!-- RobotCommand: Command (Reliable + Volatile + KeepLast1) -->
            <datawriter_qos topic_filter="RobotCommand" base_name="Patterns::Command">
            </datawriter_qos>
            <datareader_qos topic_filter="RobotCommand" base_name="Patterns::Command">
            </datareader_qos>

            <!-- RobotState: State + Deadline20ms (100 Hz continuous stream) -->
            <datawriter_qos topic_filter="RobotState" base_name="Patterns::State">
                <base_name>
                    <element>Snippets::Deadline20ms</element>
                </base_name>
            </datawriter_qos>
            <datareader_qos topic_filter="RobotState" base_name="Patterns::State">
                <base_name>
                    <element>Snippets::Deadline20ms</element>
                </base_name>
            </datareader_qos>

            <!-- SafetyInterlock: State + Liveliness500ms (write-on-change, tight lease) -->
            <datawriter_qos topic_filter="SafetyInterlock" base_name="Patterns::State">
                <base_name>
                    <element>Snippets::Liveliness500ms</element>
                </base_name>
            </datawriter_qos>
            <datareader_qos topic_filter="SafetyInterlock" base_name="Patterns::State">
                <base_name>
                    <element>Snippets::Liveliness500ms</element>
                </base_name>
            </datareader_qos>

            <!-- PatientVitals: State + Deadline2s (1 Hz periodic snapshot) -->
            <datawriter_qos topic_filter="PatientVitals" base_name="Patterns::State">
                <base_name>
                    <element>Snippets::Deadline2s</element>
                </base_name>
            </datawriter_qos>
            <datareader_qos topic_filter="PatientVitals" base_name="Patterns::State">
                <base_name>
                    <element>Snippets::Deadline2s</element>
                </base_name>
            </datareader_qos>

            <!-- WaveformData: Stream + Deadline40ms (50 Hz streaming) -->
            <datawriter_qos topic_filter="WaveformData" base_name="Patterns::Stream">
                <base_name>
                    <element>Snippets::Deadline40ms</element>
                </base_name>
            </datawriter_qos>
            <datareader_qos topic_filter="WaveformData" base_name="Patterns::Stream">
                <base_name>
                    <element>Snippets::Deadline40ms</element>
                </base_name>
            </datareader_qos>

            <!-- CameraFrame: Stream + Deadline66ms (30 Hz streaming) -->
            <datawriter_qos topic_filter="CameraFrame" base_name="Patterns::Stream">
                <base_name>
                    <element>Snippets::Deadline66ms</element>
                </base_name>
            </datawriter_qos>
            <datareader_qos topic_filter="CameraFrame" base_name="Patterns::Stream">
                <base_name>
                    <element>Snippets::Deadline66ms</element>
                </base_name>
            </datareader_qos>

            <!-- AlarmMessages: State (write-on-change, per-alarm keying) -->
            <datawriter_qos topic_filter="AlarmMessages" base_name="Patterns::State">
            </datawriter_qos>
            <datareader_qos topic_filter="AlarmMessages" base_name="Patterns::State">
            </datareader_qos>

            <!-- DeviceTelemetry: State (write-on-change) -->
            <datawriter_qos topic_filter="DeviceTelemetry" base_name="Patterns::State">
            </datawriter_qos>
            <datareader_qos topic_filter="DeviceTelemetry" base_name="Patterns::State">
            </datareader_qos>

            <!-- ProcedureContext: State (write-on-change, TRANSIENT_LOCAL) -->
            <datawriter_qos topic_filter="ProcedureContext" base_name="Patterns::State">
            </datawriter_qos>
            <datareader_qos topic_filter="ProcedureContext" base_name="Patterns::State">
            </datareader_qos>

            <!-- ProcedureStatus: State (write-on-change, TRANSIENT_LOCAL) -->
            <datawriter_qos topic_filter="ProcedureStatus" base_name="Patterns::State">
            </datawriter_qos>
            <datareader_qos topic_filter="ProcedureStatus" base_name="Patterns::State">
            </datareader_qos>

        </qos_profile>

        <!--
            HospitalTopics: topic-filter-bound QoS for Hospital domain (Domain 11).
            Every topic explicitly declares its base pattern.
        -->
        <qos_profile name="HospitalTopics">

            <!-- ClinicalAlert: State (write-on-change, reliable, TRANSIENT_LOCAL) -->
            <datawriter_qos topic_filter="ClinicalAlert" base_name="Patterns::State">
            </datawriter_qos>
            <datareader_qos topic_filter="ClinicalAlert" base_name="Patterns::State">
            </datareader_qos>

            <!-- RiskScore: State (write-on-change, reliable, TRANSIENT_LOCAL) -->
            <datawriter_qos topic_filter="RiskScore" base_name="Patterns::State">
            </datawriter_qos>
            <datareader_qos topic_filter="RiskScore" base_name="Patterns::State">
            </datareader_qos>

            <!-- ResourceAvailability: State (write-on-change, V1.1) -->
            <datawriter_qos topic_filter="ResourceAvailability" base_name="Patterns::State">
            </datawriter_qos>
            <datareader_qos topic_filter="ResourceAvailability" base_name="Patterns::State">
            </datareader_qos>

            <!-- Bridged topics from Procedure domain — same pattern as source -->
            <datareader_qos topic_filter="ProcedureStatus" base_name="Patterns::State">
            </datareader_qos>
            <datareader_qos topic_filter="ProcedureContext" base_name="Patterns::State">
            </datareader_qos>
            <datareader_qos topic_filter="PatientVitals" base_name="Patterns::State">
                <base_name>
                    <element>Snippets::Deadline2s</element>
                </base_name>
            </datareader_qos>
            <datareader_qos topic_filter="AlarmMessages" base_name="Patterns::State">
            </datareader_qos>
            <datareader_qos topic_filter="DeviceTelemetry" base_name="Patterns::State">
            </datareader_qos>
            <datareader_qos topic_filter="RobotState" base_name="Patterns::State">
                <base_name>
                    <element>Snippets::Deadline20ms</element>
                </base_name>
            </datareader_qos>

        </qos_profile>

        <!--
            GuiProcedureTopics: downsampled QoS for GUI readers on Procedure domain.
            Every topic explicitly declares its base pattern (GuiState or GuiStream).
        -->
        <qos_profile name="GuiProcedureTopics">

            <!-- State topics: GuiState (downsampled state) -->
            <datareader_qos topic_filter="RobotState" base_name="Patterns::GuiState">
                <base_name>
                    <element>Snippets::Deadline20ms</element>
                </base_name>
            </datareader_qos>
            <datareader_qos topic_filter="SafetyInterlock" base_name="Patterns::GuiState">
                <base_name>
                    <element>Snippets::Liveliness500ms</element>
                </base_name>
            </datareader_qos>
            <datareader_qos topic_filter="PatientVitals" base_name="Patterns::GuiState">
                <base_name>
                    <element>Snippets::Deadline2s</element>
                </base_name>
            </datareader_qos>
            <datareader_qos topic_filter="AlarmMessages" base_name="Patterns::GuiState">
            </datareader_qos>
            <datareader_qos topic_filter="DeviceTelemetry" base_name="Patterns::GuiState">
            </datareader_qos>
            <datareader_qos topic_filter="ProcedureContext" base_name="Patterns::GuiState">
            </datareader_qos>
            <datareader_qos topic_filter="ProcedureStatus" base_name="Patterns::GuiState">
            </datareader_qos>

            <!-- Stream topics: GuiStream (downsampled streaming) -->
            <datareader_qos topic_filter="WaveformData" base_name="Patterns::GuiStream">
                <base_name>
                    <element>Snippets::Deadline40ms</element>
                </base_name>
            </datareader_qos>
            <datareader_qos topic_filter="CameraFrame" base_name="Patterns::GuiStream">
                <base_name>
                    <element>Snippets::Deadline66ms</element>
                </base_name>
            </datareader_qos>
            <datareader_qos topic_filter="OperatorInput" base_name="Patterns::GuiStream">
                <base_name>
                    <element>Snippets::Deadline4ms</element>
                    <element>Snippets::Lifespan20ms</element>
                </base_name>
            </datareader_qos>

        </qos_profile>

        <!--
            GuiHospitalTopics: downsampled QoS for GUI readers on Hospital domain.
            Every topic explicitly declares its base pattern.
        -->
        <qos_profile name="GuiHospitalTopics">

            <datareader_qos topic_filter="ClinicalAlert" base_name="Patterns::GuiState">
            </datareader_qos>
            <datareader_qos topic_filter="RiskScore" base_name="Patterns::GuiState">
            </datareader_qos>
            <datareader_qos topic_filter="ResourceAvailability" base_name="Patterns::GuiState">
            </datareader_qos>
            <datareader_qos topic_filter="ProcedureStatus" base_name="Patterns::GuiState">
            </datareader_qos>
            <datareader_qos topic_filter="ProcedureContext" base_name="Patterns::GuiState">
            </datareader_qos>
            <datareader_qos topic_filter="PatientVitals" base_name="Patterns::GuiState">
                <base_name>
                    <element>Snippets::Deadline2s</element>
                </base_name>
            </datareader_qos>
            <datareader_qos topic_filter="AlarmMessages" base_name="Patterns::GuiState">
            </datareader_qos>
            <datareader_qos topic_filter="DeviceTelemetry" base_name="Patterns::GuiState">
            </datareader_qos>
            <datareader_qos topic_filter="RobotState" base_name="Patterns::GuiState">
                <base_name>
                    <element>Snippets::Deadline20ms</element>
                </base_name>
            </datareader_qos>

        </qos_profile>

    </qos_library>

</dds>
