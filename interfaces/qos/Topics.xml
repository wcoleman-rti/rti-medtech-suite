<?xml version="1.0" encoding="UTF-8"?>
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.6.0/rti_dds_profiles.xsd">

    <qos_library name="Topics">

        <!--
            ProcedureTopics: topic-filter-bound QoS for Procedure domain (Domain 10).
            Base pattern is State; streaming/command topics override via topic_filter.
        -->
        <qos_profile name="ProcedureTopics" base_name="Patterns::State">

            <!-- OperatorInput: Stream pattern + Deadline4ms + Lifespan20ms (500 Hz control) -->
            <datawriter_qos topic_filter="OperatorInput">
                <base_name>
                    <element>Snippets::BestEffort</element>
                    <element>Snippets::KeepLast4</element>
                    <element>Snippets::Deadline4ms</element>
                    <element>Snippets::Lifespan20ms</element>
                </base_name>
            </datawriter_qos>
            <datareader_qos topic_filter="OperatorInput">
                <base_name>
                    <element>Snippets::BestEffort</element>
                    <element>Snippets::KeepLast4</element>
                    <element>Snippets::Deadline4ms</element>
                    <element>Snippets::Lifespan20ms</element>
                </base_name>
            </datareader_qos>

            <!-- RobotCommand: Command pattern (Reliable + Volatile) -->
            <datawriter_qos topic_filter="RobotCommand">
                <base_name>
                    <element>Snippets::Volatile</element>
                </base_name>
            </datawriter_qos>
            <datareader_qos topic_filter="RobotCommand">
                <base_name>
                    <element>Snippets::Volatile</element>
                </base_name>
            </datareader_qos>

            <!-- RobotState: State pattern + Deadline20ms (100 Hz continuous stream) -->
            <datawriter_qos topic_filter="RobotState">
                <base_name>
                    <element>Snippets::Deadline20ms</element>
                </base_name>
            </datawriter_qos>
            <datareader_qos topic_filter="RobotState">
                <base_name>
                    <element>Snippets::Deadline20ms</element>
                </base_name>
            </datareader_qos>

            <!-- SafetyInterlock: State pattern + Liveliness500ms (write-on-change, tight lease) -->
            <datawriter_qos topic_filter="SafetyInterlock">
                <base_name>
                    <element>Snippets::Liveliness500ms</element>
                </base_name>
            </datawriter_qos>
            <datareader_qos topic_filter="SafetyInterlock">
                <base_name>
                    <element>Snippets::Liveliness500ms</element>
                </base_name>
            </datareader_qos>

            <!-- PatientVitals: State pattern + Deadline2s (1 Hz periodic snapshot) -->
            <datawriter_qos topic_filter="PatientVitals">
                <base_name>
                    <element>Snippets::Deadline2s</element>
                </base_name>
            </datawriter_qos>
            <datareader_qos topic_filter="PatientVitals">
                <base_name>
                    <element>Snippets::Deadline2s</element>
                </base_name>
            </datareader_qos>

            <!-- WaveformData: Stream pattern + Deadline40ms (50 Hz streaming) -->
            <datawriter_qos topic_filter="WaveformData">
                <base_name>
                    <element>Snippets::BestEffort</element>
                    <element>Snippets::KeepLast4</element>
                    <element>Snippets::Deadline40ms</element>
                </base_name>
            </datawriter_qos>
            <datareader_qos topic_filter="WaveformData">
                <base_name>
                    <element>Snippets::BestEffort</element>
                    <element>Snippets::KeepLast4</element>
                    <element>Snippets::Deadline40ms</element>
                </base_name>
            </datareader_qos>

            <!-- CameraFrame: Stream pattern + Deadline66ms (30 Hz streaming) -->
            <datawriter_qos topic_filter="CameraFrame">
                <base_name>
                    <element>Snippets::BestEffort</element>
                    <element>Snippets::KeepLast4</element>
                    <element>Snippets::Deadline66ms</element>
                </base_name>
            </datawriter_qos>
            <datareader_qos topic_filter="CameraFrame">
                <base_name>
                    <element>Snippets::BestEffort</element>
                    <element>Snippets::KeepLast4</element>
                    <element>Snippets::Deadline66ms</element>
                </base_name>
            </datareader_qos>

        </qos_profile>

        <!--
            HospitalTopics: topic-filter-bound QoS for Hospital domain (Domain 11).
            Base pattern is State; all Hospital topics are state-based (bridged or native).
        -->
        <qos_profile name="HospitalTopics" base_name="Patterns::State">

            <!-- ClinicalAlert: State pattern (write-on-change, reliable, TRANSIENT_LOCAL) -->
            <!-- Inherits base State — no overrides needed -->

            <!-- RiskScore: State pattern (write-on-change, reliable, TRANSIENT_LOCAL) -->
            <!-- Inherits base State — no overrides needed -->

        </qos_profile>

        <!--
            GuiProcedureTopics: downsampled QoS for GUI readers on Procedure domain.
            Base is GuiState; streaming topics override with GuiStream + deadline.
        -->
        <qos_profile name="GuiProcedureTopics" base_name="Patterns::GuiState">

            <!-- Streaming topics: GuiStream-equivalent + deadline -->
            <datareader_qos topic_filter="WaveformData">
                <base_name>
                    <element>Snippets::BestEffort</element>
                    <element>Snippets::KeepLast4</element>
                    <element>Snippets::Deadline40ms</element>
                    <element>Snippets::GuiSubsample</element>
                </base_name>
            </datareader_qos>

            <datareader_qos topic_filter="CameraFrame">
                <base_name>
                    <element>Snippets::BestEffort</element>
                    <element>Snippets::KeepLast4</element>
                    <element>Snippets::Deadline66ms</element>
                    <element>Snippets::GuiSubsample</element>
                </base_name>
            </datareader_qos>

            <datareader_qos topic_filter="OperatorInput">
                <base_name>
                    <element>Snippets::BestEffort</element>
                    <element>Snippets::KeepLast4</element>
                    <element>Snippets::Deadline4ms</element>
                    <element>Snippets::Lifespan20ms</element>
                    <element>Snippets::GuiSubsample</element>
                </base_name>
            </datareader_qos>

        </qos_profile>

        <!--
            GuiHospitalTopics: downsampled QoS for GUI readers on Hospital domain.
            Base is GuiState; all Hospital topics are state-based.
        -->
        <qos_profile name="GuiHospitalTopics" base_name="Patterns::GuiState">
            <!-- All Hospital topics inherit GuiState — no overrides needed -->
        </qos_profile>

    </qos_library>

</dds>
