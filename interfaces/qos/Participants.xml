<?xml version="1.0" encoding="UTF-8"?>
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.6.0/rti_dds_profiles.xsd">

    <!--
        MEDTECH_TRANSPORT_PROFILE selects the deployment-specific transport snippet.
        Default: bare-metal/native (Connext defaults: SHMEM + UDPv4, multicast ON).
        Override: set MEDTECH_TRANSPORT_PROFILE=Docker in the environment for containers.
    -->
    <configuration_variables>
        <value>
            <element>
                <name>MEDTECH_APP_NAME</name>
                <value>medtech-app</value>
            </element>
            <element>
                <name>MEDTECH_TRANSPORT_PROFILE</name>
                <value>Default</value>
            </element>
        </value>
    </configuration_variables>

    <!--
        Transport: deployment-specific transport overrides.
        Each profile is a self-contained snippet. The active snippet is
        selected at parse time via $(MEDTECH_TRANSPORT_PROFILE) variable substitution
        in the Participants::Transport base_name below.
    -->
    <qos_library name="Transport">

        <!-- Bare-metal / native development — Connext defaults are sufficient -->
        <qos_profile name="Default">
            <!-- SHMEM + UDPv4 enabled (default transport mask) -->
            <!-- Multicast enabled (default) -->
            <!-- Discovery peers: Connext defaults (multicast + localhost) -->
        </qos_profile>

        <!-- Docker simulation — multicast disabled.
             NDDS_DISCOVERY_PEERS env var supplies the per-container CDS peer
             (e.g. hospital-gateway:7400, or-1-gateway:7400).  No initial_peers
             are set here so the env var is not overridden by XML. -->
        <qos_profile name="Docker">
            <!-- <domain_participant_qos>
                <discovery>
                    <multicast_receive_addresses/>
                </discovery>
                <property>
                    <value>
                        <element>
                            <name>dds.transport.UDPv4.builtin.multicast_enabled</name>
                            <value>0</value>
                        </element>
                    </value>
                </property>
            </domain_participant_qos> -->
        </qos_profile>

    </qos_library>

    <!--
        Factory: process-level participant_factory_qos profile.
        Applies to the global DomainParticipantFactory — above any individual
        participant. Separated into its own library to make the scope boundary
        explicit.
    -->
    <qos_library name="Factory">

        <qos_profile name="FactoryDefaults"
                     is_default_participant_factory_profile="true">
            <participant_factory_qos>
                <entity_factory>
                    <autoenable_created_entities>false</autoenable_created_entities>
                </entity_factory>
                <logging>
                    <verbosity>ERROR</verbosity>
                    <category>ALL</category>
                    <print_format>VERBOSE_TIMESTAMPED</print_format>
                </logging>
                <monitoring>
                    <enable>true</enable>
                    <application_name>$(MEDTECH_APP_NAME)</application_name>
                    <distribution_settings>
                        <dedicated_participant>
                            <domain_id>19</domain_id>
                        </dedicated_participant>
                    </distribution_settings>
                    <telemetry_data>
                        <logs>
                            <user_forwarding_level>NOTICE</user_forwarding_level>
                            <middleware_forwarding_level>WARNING</middleware_forwarding_level>
                        </logs>
                        <metrics>
                            <element>
                                <resource_selection>//*</resource_selection>
                                <enabled_metrics_selection>
                                    <element>*</element>
                                </enabled_metrics_selection>
                            </element>
                        </metrics>
                    </telemetry_data>
                </monitoring>
            </participant_factory_qos>
        </qos_profile>

    </qos_library>

    <!--
        Participants: common participant-level QoS. The Transport profile
        composes AvoidIPFragmentation (universal best practice) and the
        deployment-selected transport snippet via $(TRANSPORT_PROFILE).
    -->
    <qos_library name="Participants">

        <qos_profile name="Transport">
            <base_name>
                <element>BuiltinQosSnippetLib::Transport.UDP.AvoidIPFragmentation</element>
                <element>Transport::$(MEDTECH_TRANSPORT_PROFILE)</element>
            </base_name>
        </qos_profile>

    </qos_library>

</dds>
