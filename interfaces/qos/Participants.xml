<?xml version="1.0" encoding="UTF-8"?>
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.6.0/rti_dds_profiles.xsd">

    <qos_library name="Participants">

        <!--
            FactoryDefaults: participant_factory_qos profile applied to all applications.
            Sets logging verbosity, Monitoring Library 2.0 config, and is the
            is_default_participant_factory_profile.
        -->
        <qos_profile name="FactoryDefaults"
                     is_default_participant_factory_profile="true">
            <participant_factory_qos>
                <logging>
                    <verbosity>WARNING</verbosity>
                    <category>ALL</category>
                    <print_format>VERBOSE_TIMESTAMPED</print_format>
                </logging>
                <monitoring>
                    <enable>true</enable>
                    <distribution_settings>
                        <dedicated_participant>
                            <domain_id>20</domain_id>
                        </dedicated_participant>
                    </distribution_settings>
                    <telemetry_data>
                        <logs>
                            <user_forwarding_level>NOTICE</user_forwarding_level>
                            <middleware_forwarding_level>WARNING</middleware_forwarding_level>
                        </logs>
                    </telemetry_data>
                </monitoring>
            </participant_factory_qos>
        </qos_profile>

        <!--
            SimulationTransport: participant QoS for local simulation.
            Disables shared memory (UDPv4 only), disables multicast.
            Initial peers left as default (SHMEM peer nullified by UDPv4 mask).
        -->
        <qos_profile name="SimulationTransport"
                     is_default_qos="true">
            <domain_participant_qos>
                <transport_builtin>
                    <mask>UDPv4</mask>
                </transport_builtin>
                <discovery>
                    <multicast_receive_addresses/>
                </discovery>
            </domain_participant_qos>
        </qos_profile>

    </qos_library>

</dds>
