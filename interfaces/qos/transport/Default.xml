<?xml version="1.0" encoding="UTF-8"?>
<!--
    Default transport profile — bare-metal / native development.

    SHMEM + UDPv4 enabled (Connext default transport mask).
    Multicast enabled (Connext default).
    Discovery addresses: Connext defaults (multicast + localhost).
    AvoidIPFragmentation composed as a general best practice.

    All participant XML references this profile as Participants::Transport.
    The Docker variant (Docker.xml) overrides multicast and discovery
    settings for container environments.
-->
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.6.0/rti_dds_profiles.xsd">

    <qos_library name="Participants">

        <qos_profile name="Transport">
            <base_name>
                <element>BuiltinQosSnippetLib::Transport.UDP.AvoidIPFragmentation</element>
            </base_name>
            <!-- Default transport mask: SHMEM + UDPv4 -->
            <!-- Default multicast: enabled -->
            <!-- Default discovery addresses: Connext defaults -->
        </qos_profile>

    </qos_library>

</dds>
