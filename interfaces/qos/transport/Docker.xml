<?xml version="1.0" encoding="UTF-8"?>
<!--
    Docker transport profile — container simulation environment.

    SHMEM + UDPv4 enabled (Connext default transport mask).
    SHMEM is beneficial for intra-container communication (multiple
    participants or processes within the same container).

    Multicast DISABLED:
      - multicast_receive_addresses cleared (no multicast receive)
      - dds.transport.UDPv4.builtin.multicast_enabled = 0 (no multicast send)
    Docker bridge networks do not reliably support multicast.

    Initial peers explicitly set for Docker:
      1. builtin.shmem://           — intra-container SHMEM discovery
      2. builtin.udpv4://localhost   — intra-container UDPv4 discovery
      3. rtps@udpv4://cloud-discovery-service:7400 — CDS for cross-container
    This excludes the default multicast discovery address.

    AvoidIPFragmentation composed to prevent IP fragmentation on Docker
    overlay networks where MTU may be smaller than expected.

    All participant XML references this profile as Participants::Transport.
    Deployment selects this file or Default.xml via NDDS_QOS_PROFILES.
-->
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.6.0/rti_dds_profiles.xsd">

    <qos_library name="Participants">

        <qos_profile name="Transport">
            <base_name>
                <element>BuiltinQosSnippetLib::Transport.UDP.AvoidIPFragmentation</element>
            </base_name>
            <domain_participant_qos>
                <discovery>
                    <initial_peers>
                        <element>builtin.shmem://</element>
                        <element>builtin.udpv4://localhost</element>
                        <element>rtps@udpv4://cloud-discovery-service:7400</element>
                    </initial_peers>
                    <multicast_receive_addresses/>
                </discovery>
                <property>
                    <value>
                        <element>
                            <name>dds.transport.UDPv4.builtin.multicast_enabled</name>
                            <value>0</value>
                        </element>
                    </value>
                </property>
            </domain_participant_qos>
        </qos_profile>

    </qos_library>

</dds>
