<?xml version="1.0" encoding="UTF-8"?>
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.6.0/rti_dds_profiles.xsd">

    <qos_library name="Patterns">

        <!--
            State: latest-state data (vitals, device status, robot state, alarms).
            Base provides Reliable + KeepLast1 + TransientLocal + ReliabilityProtocol.KeepLast.
            LivelinessStandard composed for writer-health detection on write-on-change topics.
        -->
        <qos_profile name="State">
            <base_name>
                <element>BuiltinQosLib::Generic.KeepLastReliable.TransientLocal</element>
                <element>Snippets::LivelinessStandard</element>
            </base_name>
        </qos_profile>

        <!--
            Command: volatile reliable commands (no stale delivery to late joiners).
            Base provides Reliable + KeepLast1 + ReliabilityProtocol.KeepLast.
            Volatile durability is the Connext default — no explicit override needed.
        -->
        <qos_profile name="Command"
                     base_name="BuiltinQosLib::Generic.KeepLastReliable">
        </qos_profile>

        <!--
            Stream: high-rate best-effort streaming (waveforms, camera, operator input).
            Base provides BestEffort + KeepLast (depth 100 by default).
            Writer depth overridden to 1 (no repair cache needed for best-effort).
            Reader depth overridden to 4 (buffer for bursty arrival).
        -->
        <qos_profile name="Stream"
                     base_name="BuiltinQosLib::Generic.BestEffort">
            <datawriter_qos>
                <history>
                    <kind>KEEP_LAST_HISTORY_QOS</kind>
                    <depth>1</depth>
                </history>
            </datawriter_qos>
            <datareader_qos>
                <history>
                    <kind>KEEP_LAST_HISTORY_QOS</kind>
                    <depth>4</depth>
                </history>
            </datareader_qos>
        </qos_profile>

        <!-- GuiState: downsampled state for GUI readers -->
        <qos_profile name="GuiState"
                     base_name="Patterns::State">
            <base_name>
                <element>Snippets::GuiSubsample</element>
            </base_name>
        </qos_profile>

        <!-- GuiStream: downsampled streaming for GUI readers -->
        <qos_profile name="GuiStream"
                     base_name="Patterns::Stream">
            <base_name>
                <element>Snippets::GuiSubsample</element>
            </base_name>
        </qos_profile>

        <!--
            RPC: inherits from the RTI builtin RPC pattern which provides
            RELIABLE + KEEP_ALL + correlation + optimized transport settings.
            Used by ServiceHostControl and future RPC interfaces.
        -->
        <qos_profile name="RPC"
                     base_name="BuiltinQosLib::Pattern.RPC">
        </qos_profile>

    </qos_library>

</dds>
