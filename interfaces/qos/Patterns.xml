<?xml version="1.0" encoding="UTF-8"?>
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.6.0/rti_dds_profiles.xsd">

    <qos_library name="Patterns">

        <!-- State: latest-state data (vitals, device status, robot state, alarms) -->
        <qos_profile name="State"
                     base_name="BuiltinQosLib::Generic.Common">
            <datawriter_qos>
                <base_name>
                    <element>Snippets::Reliable</element>
                    <element>Snippets::TransientLocal</element>
                    <element>Snippets::KeepLast1</element>
                    <element>Snippets::Liveliness2s</element>
                </base_name>
            </datawriter_qos>
            <datareader_qos>
                <base_name>
                    <element>Snippets::Reliable</element>
                    <element>Snippets::TransientLocal</element>
                    <element>Snippets::KeepLast1</element>
                    <element>Snippets::Liveliness2s</element>
                </base_name>
            </datareader_qos>
        </qos_profile>

        <!-- Command: volatile reliable commands (no stale delivery to late joiners) -->
        <qos_profile name="Command"
                     base_name="BuiltinQosLib::Generic.Common">
            <datawriter_qos>
                <base_name>
                    <element>Snippets::Reliable</element>
                    <element>Snippets::Volatile</element>
                    <element>Snippets::KeepLast1</element>
                </base_name>
            </datawriter_qos>
            <datareader_qos>
                <base_name>
                    <element>Snippets::Reliable</element>
                    <element>Snippets::Volatile</element>
                    <element>Snippets::KeepLast1</element>
                </base_name>
            </datareader_qos>
        </qos_profile>

        <!-- Stream: high-rate best-effort streaming (waveforms, camera, operator input) -->
        <qos_profile name="Stream"
                     base_name="BuiltinQosLib::Generic.Common">
            <datawriter_qos>
                <base_name>
                    <element>Snippets::BestEffort</element>
                    <element>Snippets::KeepLast4</element>
                </base_name>
            </datawriter_qos>
            <datareader_qos>
                <base_name>
                    <element>Snippets::BestEffort</element>
                    <element>Snippets::KeepLast4</element>
                </base_name>
            </datareader_qos>
        </qos_profile>

        <!-- GuiState: downsampled state for GUI readers -->
        <qos_profile name="GuiState"
                     base_name="Patterns::State">
            <datareader_qos>
                <base_name>
                    <element>Snippets::GuiSubsample</element>
                </base_name>
            </datareader_qos>
        </qos_profile>

        <!-- GuiStream: downsampled streaming for GUI readers -->
        <qos_profile name="GuiStream"
                     base_name="Patterns::Stream">
            <datareader_qos>
                <base_name>
                    <element>Snippets::GuiSubsample</element>
                </base_name>
            </datareader_qos>
        </qos_profile>

    </qos_library>

</dds>
