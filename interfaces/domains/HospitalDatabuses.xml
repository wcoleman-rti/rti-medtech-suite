<?xml version="1.0" encoding="UTF-8"?>
<!--
    Hospital-level domain library: Hospital Integration and Hospital
    Observability databuses. These domains span the entire facility.

    Domain ID Migration History (revision-domain-id-migration):
      Hospital: 11 → 20 (integration plane, decade-offset)
      HospitalObservability: new → 29 (aggregated telemetry)
-->
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.6.0/rti_dds_profiles.xsd">

    <domain_library name="Hospital">

        <!--
            Hospital Integration databus (Domain 20)
            Flat domain, no tags. Bridged + native topics.
        -->
        <domain name="Integration" domain_id="20">
            <!-- Bridged types from Procedure databuses -->
            <register_type name="Surgery::ProcedureStatus"     type_ref="Surgery::ProcedureStatus"/>
            <register_type name="Surgery::ProcedureContext"    type_ref="Surgery::ProcedureContext"/>
            <register_type name="Monitoring::PatientVitals"   type_ref="Monitoring::PatientVitals"/>
            <register_type name="Monitoring::AlarmMessage"    type_ref="Monitoring::AlarmMessage"/>
            <register_type name="Devices::DeviceTelemetry"    type_ref="Devices::DeviceTelemetry"/>
            <register_type name="Surgery::RobotState"         type_ref="Surgery::RobotState"/>
            <!-- Bridged types from Orchestration databus -->
            <register_type name="Orchestration::ServiceCatalog" type_ref="Orchestration::ServiceCatalog"/>
            <!-- Native Hospital types -->
            <register_type name="ClinicalAlerts::ClinicalAlert" type_ref="ClinicalAlerts::ClinicalAlert"/>
            <register_type name="ClinicalAlerts::RiskScore"     type_ref="ClinicalAlerts::RiskScore"/>
            <register_type name="Hospital::ResourceAvailability" type_ref="Hospital::ResourceAvailability"/>

            <!-- Bridged topics -->
            <topic name="ProcedureStatus"  register_type_ref="Surgery::ProcedureStatus"/>
            <topic name="ProcedureContext" register_type_ref="Surgery::ProcedureContext"/>
            <topic name="PatientVitals"    register_type_ref="Monitoring::PatientVitals"/>
            <topic name="AlarmMessages"    register_type_ref="Monitoring::AlarmMessage"/>
            <topic name="DeviceTelemetry"  register_type_ref="Devices::DeviceTelemetry"/>
            <topic name="RobotState"       register_type_ref="Surgery::RobotState"/>
            <!-- Bridged from Orchestration databus -->
            <topic name="ServiceCatalog"   register_type_ref="Orchestration::ServiceCatalog"/>
            <!-- Native topics -->
            <topic name="ClinicalAlert"    register_type_ref="ClinicalAlerts::ClinicalAlert"/>
            <topic name="RiskScore"        register_type_ref="ClinicalAlerts::RiskScore"/>
            <topic name="ResourceAvailability" register_type_ref="Hospital::ResourceAvailability"/>
        </domain>

        <!--
            Hospital Observability databus — Domain ID 29 (reserved)
            Aggregated telemetry: room-forwarded (from Room Observability
            databus) + hospital-native. Collector Service forwards to
            Cloud Observability databus (V3.0).
            No registered types or topics.

            Commented out: empty domain elements cause Routing Service
            XML validation errors.
        -->
        <!-- <domain name="Observability" domain_id="29"/> -->

    </domain_library>

</dds>
