<?xml version="1.0" encoding="UTF-8"?>
<!--
    Room-level domain library: Procedure, Orchestration, and Room Observability
    databuses. All domains in this library are scoped to a single operating room.

    Domain ID Migration History (revision-domain-id-migration):
      Orchestration: 15 → 11 (room-scoped control plane)
      RoomObservability: new → 19 (Monitoring Library 2.0 per-room)
      Procedure: 10 → 10 (unchanged)
-->
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.6.0/rti_dds_profiles.xsd">

    <domain_library name="Room">

        <!--
            Procedure control databus (Domain 10, tag: control)
            Class C / Class III (safety-critical)
        -->
        <domain name="Procedure_control" domain_id="10">
            <register_type name="Surgery::RobotCommand"         type_ref="Surgery::RobotCommand"/>
            <register_type name="Surgery::RobotState"           type_ref="Surgery::RobotState"/>
            <register_type name="Surgery::SafetyInterlock"      type_ref="Surgery::SafetyInterlock"/>
            <register_type name="Surgery::OperatorInput"        type_ref="Surgery::OperatorInput"/>
            <register_type name="Surgery::RobotArmAssignment"   type_ref="Surgery::RobotArmAssignment"/>

            <topic name="RobotCommand"          register_type_ref="Surgery::RobotCommand"/>
            <topic name="RobotState"            register_type_ref="Surgery::RobotState"/>
            <topic name="SafetyInterlock"       register_type_ref="Surgery::SafetyInterlock"/>
            <topic name="OperatorInput"         register_type_ref="Surgery::OperatorInput"/>
            <topic name="RobotArmAssignment"    register_type_ref="Surgery::RobotArmAssignment"/>
        </domain>

        <!--
            Procedure clinical databus (Domain 10, tag: clinical)
            Class B / Class II (clinical significance)
        -->
        <domain name="Procedure_clinical" domain_id="10">
            <register_type name="Monitoring::PatientVitals"   type_ref="Monitoring::PatientVitals"/>
            <register_type name="Monitoring::WaveformData"    type_ref="Monitoring::WaveformData"/>
            <register_type name="Monitoring::AlarmMessage"   type_ref="Monitoring::AlarmMessage"/>
            <register_type name="Devices::DeviceTelemetry"    type_ref="Devices::DeviceTelemetry"/>

            <topic name="PatientVitals"   register_type_ref="Monitoring::PatientVitals"/>
            <topic name="WaveformData"    register_type_ref="Monitoring::WaveformData"/>
            <topic name="AlarmMessages"   register_type_ref="Monitoring::AlarmMessage"/>
            <topic name="DeviceTelemetry" register_type_ref="Devices::DeviceTelemetry"/>
        </domain>

        <!--
            Procedure operational databus (Domain 10, tag: operational)
            Class A / Class I (non-critical)
        -->
        <domain name="Procedure_operational" domain_id="10">
            <register_type name="Imaging::CameraFrame"         type_ref="Imaging::CameraFrame"/>
            <register_type name="Imaging::CameraConfig"         type_ref="Imaging::CameraConfig"/>
            <register_type name="Surgery::ProcedureContext"    type_ref="Surgery::ProcedureContext"/>
            <register_type name="Surgery::ProcedureStatus"     type_ref="Surgery::ProcedureStatus"/>

            <topic name="CameraFrame"      register_type_ref="Imaging::CameraFrame"/>
            <topic name="CameraConfig"     register_type_ref="Imaging::CameraConfig"/>
            <topic name="ProcedureContext" register_type_ref="Surgery::ProcedureContext"/>
            <topic name="ProcedureStatus"  register_type_ref="Surgery::ProcedureStatus"/>
        </domain>

        <!--
            Orchestration databus (Domain 11)
            Infrastructure lifecycle control-plane. No domain tags.
            Pub/sub: ServiceCatalog, ServiceStatus
            RPC: ServiceHostControl (generated topics managed by RPC layer)
        -->
        <domain name="Orchestration" domain_id="11">
            <register_type name="Orchestration::ServiceCatalog"   type_ref="Orchestration::ServiceCatalog"/>
            <register_type name="Orchestration::ServiceStatus"   type_ref="Orchestration::ServiceStatus"/>

            <topic name="ServiceCatalog"  register_type_ref="Orchestration::ServiceCatalog"/>
            <topic name="ServiceStatus"  register_type_ref="Orchestration::ServiceStatus"/>
        </domain>

        <!--
            Room Observability databus — Domain ID 19 (reserved)
            Monitoring Library 2.0 per-room telemetry. Collector Service
            subscribes here and forwards to the Hospital Observability databus.
            No registered types or topics (Monitoring Library manages its
            own entities on this domain).

            Commented out: empty domain elements cause Routing Service
            XML validation errors.
        -->
        <!-- <domain name="Observability" domain_id="19"/> -->

    </domain_library>

</dds>
